#                                               -*- Autoconf -*-
# Process this file with autoconf to produce a configure script.

AC_PREREQ([2.63])
AC_INIT([service_provider_process_data_inspection], [PACKAGE_VERSION], [Robert Burger <robert.burger@dlr.de>])
AM_INIT_AUTOMAKE([-Wall -Werror foreign subdir-objects])
AC_CONFIG_HEADERS([config.h])
AC_CONFIG_MACRO_DIR([m4])

# Checks for programs.
m4_ifdef([AM_PROG_AR], [AM_PROG_AR])
AC_PROG_CXX
AX_CXX_COMPILE_STDCXX(14, [ext], [mandatory])
AC_PROG_INSTALL
AC_PROG_LIBTOOL
AC_PROG_LN_S
m4_ifdef([PKG_PROG_PKG_CONFIG], [PKG_PROG_PKG_CONFIG])
m4_ifdef([PKG_INSTALLDIR], [PKG_INSTALLDIR], [pkgconfigdir='${libdir}/pkgconfig' AC_SUBST([pkgconfigdir])])
AC_PATH_PROG(SERVICE_GENERATE, service_generate)
AS_IF([test "$SERVICE_GENERATE" = ""], [AC_MSG_ERROR(["service_generate not found. Install robotkernel-service-helper!"])], [])

# Check dependencies
PKG_CHECK_MODULES([ROBOTKERNEL], [robotkernel])

# Checks for header files.
AC_CHECK_HEADERS([stdlib.h string.h])

# Checks for typedefs, structures, and compiler characteristics.
AC_TYPE_SIZE_T

# Checks for library functions.
AC_CHECK_LIB(dl, dlopen)

AC_CONFIG_FILES([Makefile src/Makefile service_provider_process_data_inspection.pc])

AC_OUTPUT

